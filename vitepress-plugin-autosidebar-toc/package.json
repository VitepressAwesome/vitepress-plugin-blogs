{
  "name": "@knewbeing/vitepress-plugin-autosidebar-toc",
  "version": "0.1.0",
  "description": "Auto-generate sidebar, navigation, and blog components for VitePress. Provides Markdown scanning, metadata extraction, and ready-to-use components (BlogHome, AutoToc, SidebarArticleList).",
  "keywords": [
    "vitepress",
    "sidebar",
    "navigation",
    "blog",
    "markdown",
    "documentation",
    "vite-plugin",
    "vue3",
    "typescript"
  ],
  "license": "MIT",
  "author": {
    "name": "知在",
    "email": "zz@dmsrs.org",
    "url": "https://www.dmsrs.org"
  },
  "homepage": "https://github.com/VitepressAwesome/vitepress-plugin-blogs#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VitepressAwesome/vitepress-plugin-blogs.git",
    "directory": "vitepress-plugin-autosidebar-toc"
  },
  "bugs": {
    "url": "https://github.com/VitepressAwesome/vitepress-plugin-blogs/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "dist",
    "client/AutoToc.vue",
    "client/BlogHome.vue",
    "client/SidebarArticleList.vue",
    "client/TagsCloud.vue",
    "client/useTocEntries.ts",
    "client/useBlogHome.ts",
    "client/useIndexTagsStore.ts",
    "client/useTocSidebarConfig.ts",
    "client/style.css",
    "globals.d.ts"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "sanitize-html": "^2.17.2"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "@types/sanitize-html": "^2.16.1",
    "tsup": "^8.5.0",
    "typescript": "^6.0.2",
    "unplugin-vue-components": "^30.0.0",
    "vite": "^7.3.2",
    "vitepress": "2.0.0-alpha.15",
    "vue": "^3.5.32"
  },
  "peerDependencies": {
    "vite": "*",
    "vitepress": "*",
    "vue": "^3.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./client/AutoToc.vue": "./client/AutoToc.vue",
    "./client/BlogHome.vue": "./client/BlogHome.vue",
    "./client/SidebarArticleList.vue": "./client/SidebarArticleList.vue",
    "./client/useTocEntries": "./client/useTocEntries.ts",
    "./client/useBlogHome": "./client/useBlogHome.ts",
    "./client/useIndexTagsStore": "./client/useIndexTagsStore.ts",
    "./client/useTocSidebarConfig": "./client/useTocSidebarConfig.ts",
    "./client/TagsCloud.vue": "./client/TagsCloud.vue",
    "./client/style.css": "./client/style.css"
  }
}
