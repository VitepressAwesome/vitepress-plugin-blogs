{
  "name": "@knewbeing/vitepress-plugin-nolebase",
  "version": "1.0.0",
  "description": "Vendored nolebase integrations for VitePress — enhanced-readabilities, git-changelog, inline-link-preview, highlight-targeted-heading, index, and more. Derived from @nolebase/integrations (MIT).",
  "keywords": [
    "vitepress",
    "nolebase",
    "enhanced-readabilities",
    "git-changelog",
    "inline-link-preview",
    "vite-plugin",
    "typescript"
  ],
  "license": "MIT",
  "author": {
    "name": "知在",
    "email": "zz@dmsrs.org",
    "url": "https://www.dmsrs.org"
  },
  "type": "module",
  "scripts": {
    "build": "tsup"
  },
  "exports": {
    ".": "./src/index.ts",
    "./vitepress/client": "./src/vitepress/client/index.ts",
    "./vitepress/vite": {
      "import": "./dist/vitepress/vite.js",
      "types": "./src/vitepress/vite/index.ts"
    },
    "./vitepress/markdown-it": {
      "import": "./dist/vitepress/markdown-it.js",
      "types": "./src/vitepress/markdown-it/index.ts"
    }
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "vite": "*",
    "vitepress": "*",
    "vue": "^3.0.0"
  },
  "dependencies": {
    "defu": "*",
    "@knewbeing/ui": "workspace:*",
    "@knewbeing/markdown-it-element-transform": "workspace:*",
    "@knewbeing/markdown-it-bi-directional-links": "workspace:*",
    "@knewbeing/markdown-it-unlazy-img": "workspace:*",
    "@knewbeing/vitepress-plugin-enhanced-mark": "workspace:*",
    "@knewbeing/vitepress-plugin-enhanced-readabilities": "workspace:*",
    "@knewbeing/vitepress-plugin-git-changelog": "workspace:*",
    "@knewbeing/vitepress-plugin-highlight-targeted-heading": "workspace:*",
    "@knewbeing/vitepress-plugin-index": "workspace:*",
    "@knewbeing/vitepress-plugin-inline-link-preview": "workspace:*",
    "@knewbeing/vitepress-plugin-meta": "workspace:*"
  }
}
